# Development Environment Configuration
# For physical device testing, use your computer's IP address (e.g., 192.168.x.x:3000)
# Run 'ipconfig' on Windows to find your IP address

# PowerSync Configuration
POWERSYNC_URL=https://your-instance.powersync.co

# PostgreSQL API
POSTGRES_API_URL=http://192.168.0.101:3000/api

# JWT Auth
JWT_SECRET=dev-jwt-secret-key
JWT_EXPIRY_HOURS=24

# App
APP_NAME=IMU Dev
DEBUG_MODE=true
LOG_LEVEL=debug

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Note: 10.0.2.2 is the Android emulator's way to access host localhost
# For iOS simulator or physical devices, use your computer's actual IP (e.g., 192.168.1.100:3000)
