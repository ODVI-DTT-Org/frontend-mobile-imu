# Development Environment Configuration
# For physical device testing, use your computer's IP address (e.g., 192.168.x.x:3000)
# Run 'ipconfig' on Windows to find your IP address

# PowerSync Configuration
# PowerSync instance URL for sync service
POWERSYNC_URL=https://69ba260fe44c66e817793c98.powersync.journeyapps.com

# PostgreSQL API (Backend)
# Use computer's IP address for physical device testing
POSTGRES_API_URL=http://192.168.131.70:3000/api

# JWT Auth (must match backend)
JWT_SECRET=dev-jwt-secret-key-min-32-characters-long-for-security
JWT_EXPIRY_HOURS=24

# App
APP_NAME=IMU Dev
DEBUG_MODE=true
LOG_LEVEL=debug

# AWS Configuration (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Note: 10.0.2.2 is the Android emulator's way to access host localhost
# For iOS simulator or physical devices, use your computer's actual IP (e.g., 192.168.1.100:3000)
# For web/Chrome, localhost works directly
