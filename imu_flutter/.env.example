# PowerSync Configuration
# For PowerSync Cloud: https://your-instance.powersync.co
# For local development: leave empty (mock mode)
POWERSYNC_URL=

# PostgreSQL API (Backend)
# For local development: http://localhost:3000/api
# For physical devices: http://YOUR_IP:3000/api
POSTGRES_API_URL=http://localhost:3000/api

# JWT Auth (must match backend .env)
JWT_SECRET=your-jwt-secret-key-min-32-characters
JWT_EXPIRY_HOURS=24

# App
APP_NAME=IMU
DEBUG_MODE=false
LOG_LEVEL=info

# AWS Configuration (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Note: For physical device testing, use your computer's IP address
# Run 'ipconfig' on Windows or 'ifconfig' on macOS/Linux to find your IP
