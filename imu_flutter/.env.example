# PowerSync Configuration
POWERSYNC_URL=https://your-instance.powersync.co

# PostgreSQL API
POSTGRES_API_URL=http://localhost:3000/api

# JWT Auth
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY_HOURS=24

# App
APP_NAME=IMU
DEBUG_MODE=false
LOG_LEVEL=info

# AWS Configuration (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Note: For physical device testing, use your computer's IP address
# Run 'ipconfig' on Windows or 'ifconfig' on macOS/Linux to find your IP
