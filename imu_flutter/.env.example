# PowerSync Configuration
# Production PowerSync instance
POWERSYNC_URL=https://69cb46b4f69619e9d4830ea1.powersync.journeyapps.com

# PostgreSQL Direct Connection (PowerSync replication)
# IMPORTANT: Set this via environment variable, NOT in this file
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# DO NOT commit actual credentials to git
POWERSYNC_POSTGRES_URI=

# PostgreSQL API (Backend)
# Development now uses production backend
POSTGRES_API_URL=https://imu-api.cfbtools.app/api

# JWT Auth (must match backend .env)
JWT_SECRET=your-jwt-secret-key-min-32-characters
JWT_EXPIRY_HOURS=24

# PowerSync JWT Secret (set via environment variable)
POWERSYNC_JWT_SECRET=your-powersync-jwt-secret-here

# App
APP_NAME=IMU
DEBUG_MODE=false
LOG_LEVEL=info

# AWS Configuration (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# Mapbox Configuration
# Get your access token from https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12
MAP_DEFAULT_ZOOM=15.0
MAP_MIN_ZOOM=10.0
MAP_MAX_ZOOM=20.0
MAP_ENABLE_CLUSTERING=true
MAP_CLUSTER_RADIUS=50
MAP_OFFLINE_ENABLED=false

# Note: For physical device testing, use your computer's IP address
# Run 'ipconfig' on Windows or 'ifconfig' on macOS/Linux to find your IP
