# ===========================================
# IMU Environment Configuration Example
# ===========================================
# Copy this file to .env, .env.dev, .env.qa, or .env.prod
# Update the values with your actual configuration

# -------------------
# PowerSync Configuration
# -------------------
# Production PowerSync instance
# NOTE: PowerSync handles database replication on the backend
# The mobile app connects to PowerSync using JWT tokens from the backend
POWERSYNC_URL=https://69cd6b238fa42c16d7f725a9.powersync.journeyapps.com

# -------------------
# Backend API (REST API)
# -------------------
# IMPORTANT: This is the REST API endpoint, NOT a direct database connection
# All database operations go through the backend API
BACKEND_API_URL=https://imu-api.cfbtools.app/api

# Legacy name (kept for backward compatibility)
POSTGRES_API_URL=https://imu-api.cfbtools.app/api

# -------------------
# JWT Authentication
# -------------------
# NOTE: Mobile app doesn't use this for JWT generation
# The backend handles all JWT signing and verification
# This is required by AppConfig.initialize() for validation
JWT_SECRET=your-jwt-secret-key-min-32-characters
JWT_EXPIRY_HOURS=24

# -------------------
# App Configuration
# -------------------
APP_NAME=IMU
DEBUG_MODE=false
LOG_LEVEL=info

# -------------------
# Analytics (PostHog)
# -------------------
# PostHog analytics for tracking user behavior and app performance
# Get your key from https://app.posthog.com/project/settings
POSTHOG_KEY=your-posthog-project-api-key
POSTHOG_HOST=https://us.i.posthog.com

# -------------------
# AWS Configuration (optional)
# -------------------
# For S3 file uploads (if needed)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# -------------------
# Mapbox Configuration
# -------------------
# Get your access token from https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12
MAP_DEFAULT_ZOOM=15.0
MAP_MIN_ZOOM=10.0
MAP_MAX_ZOOM=20.0
MAP_ENABLE_CLUSTERING=true
MAP_CLUSTER_RADIUS=50
MAP_OFFLINE_ENABLED=false

# -------------------
# Notes
# -------------------
# - DO NOT commit actual credentials to git
# - For physical device testing, use your computer's IP address
# - Run 'ipconfig' on Windows or 'ifconfig' on macOS/Linux to find your IP
